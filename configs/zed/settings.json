{
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "agent": {
    "default_model": {
      "model": "claude-3-5-sonnet-latest",
      "provider": "zed.dev"
    },
    "default_open_ai_model": null,
    "enabled": true,
  },
  "auto_install_extensions": {
    "make": true,
    "nix": true,
    "toml": true
  },
  "auto_update": false,
  "base_keymap": "VSCode",
  "buffer_font_size": 16,
  "helix_mode": true,
  "hour_format": "hour24",
  "languages": {},
  "load_direnv": "shell_hook",
  "lsp": {
    "elixir-ls": {
      "binary": {
        "path_lookup": true
      },
      "settings": {
        "dialyzerEnabled": true
      }
    },
    "nix": {
      "binary": {
        "path_lookup": true
      }
    },
    "rust-analyzer": {
      "binary": {
        "path_lookup": true
      }
    }
  },
  "show_whitespaces": "all",
  "terminal": {
    "alternate_scroll": "off",
    "blinking": "off",
    "button": false,
    "copy_on_select": false,
    "detect_venv": {
      "on": {
        "activate_script": "default",
        "directories": [
          ".env",
          "env",
          ".venv",
          "venv"
        ]
      }
    },
    "dock": "bottom",
    "env": {
      "TERM": "konsole"
    },
    "font_family": "FiraCode Nerd Font",
    "font_features": null,
    "font_size": null,
    "line_height": "comfortable",
    "option_as_meta": false,
    "shell": "system",
    "toolbar": {
      "title": true
    },
    "working_directory": "current_project_directory"
  },
  "theme": {
    "dark": "Ayu Dark",
    "light": "Ayu Light",
    "mode": "dark"
  },
  "ui_font_size": 16,
  "vim_mode": true
}
